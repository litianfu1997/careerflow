generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nickname     String?
  role         String   @default("user") // user | admin
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  resumes      Resume[]
  apiKeys      ApiKey[]
  patches      ResumePatch[]
  versions     ResumeVersion[]
  auditLogs    AgentAuditLog[]
  templates    ResumeTemplate[]

  @@map("users")
}

model Resume {
  id           String   @id @default(cuid())
  userId       String
  title        String
  contentJson  Json
  templateId   String?
  status       String   @default("draft") // draft | published
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template     ResumeTemplate?  @relation(fields: [templateId], references: [id])
  exports      ResumeExport[]
  patches      ResumePatch[]
  versions     ResumeVersion[]

  @@index([userId])
  @@map("resumes")
}

model ResumeTemplate {
  id           String    @id @default(cuid())
  name         String    @unique
  displayName  String
  description  String?
  previewUrl   String?
  isBuiltin    Boolean   @default(false)
  templateHtml String?
  templateCss  String?
  userId       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumes      Resume[]

  @@index([userId])
  @@map("resume_templates")
}

model ResumeExport {
  id         String   @id @default(cuid())
  resumeId   String
  userId     String
  format     String   // json | markdown | pdf
  fileUrl    String?
  createdAt  DateTime @default(now())

  resume     Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@index([userId])
  @@map("resume_exports")
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String
  name         String
  keyHash      String   @unique
  keyPrefix    String   // first 12 chars for display
  scopes       String[] // ["resume:read", "resume:write_patch", ...]
  status       String   @default("active") // active | revoked
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  patches      ResumePatch[]
  auditLogs    AgentAuditLog[]

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

model ResumePatch {
  id           String    @id @default(cuid())
  resumeId     String
  userId       String
  apiKeyId     String?
  title        String
  description  String?
  patchJson    Json      // JSON Pointer operations
  status       String    @default("pending_review") // pending_review | applied | rejected | expired
  appliedAt    DateTime?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  resume       Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id])
  apiKey       ApiKey?   @relation(fields: [apiKeyId], references: [id])

  @@index([resumeId])
  @@index([userId])
  @@index([status])
  @@map("resume_patches")
}

model ResumeVersion {
  id          String   @id @default(cuid())
  resumeId    String
  userId      String
  contentJson Json
  versionNote String?
  createdAt   DateTime @default(now())

  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@index([resumeId])
  @@map("resume_versions")
}

model AgentAuditLog {
  id        String   @id @default(cuid())
  userId    String
  apiKeyId  String?
  action    String
  resource  String?
  detail    Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  apiKey    ApiKey?  @relation(fields: [apiKeyId], references: [id])

  @@index([userId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@map("agent_audit_logs")
}
